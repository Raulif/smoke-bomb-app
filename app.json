{
  "expo": {
    "name": "smoke-bomb-app",
    "slug": "smoke-bomb-app",
    "scheme": "smokebomb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.smokebombapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#FF6B35"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Smoke Bomb uses your location to detect when you arrive home during an active game.",
          "locationAlwaysAndWhenInUsePermission": "Smoke Bomb needs background location to automatically detect when you arrive home, even when the app is minimized.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ]
  }
}
